# Build output
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Dd]ebugPublic/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
build/
bld/

# Visual Studio working files / IDE state
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
.vscode/settings.json

# Build / test / coverage results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml

# NuGet
packages/
*.nupkg
*.snupkg
.nuget/
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets

# Visual Studio Installer / setup project output
[Dd]ebug*/
[Rr]elease*/
*.[Cc]ache

# Misc compiled / temp artifacts
*.pdb
*.dll
*.exe
*.tmp
*.log
*.tlog
*.ilk
*.meta
*.obj

# OS files
Thumbs.db
[Tt]humbs.db
ehthumbs.db
desktop.ini
.DS_Store

# Legacy source-control metadata (CVS / Visual SourceSafe / SVN leftovers)
CVS/
.cvsignore
.svn/
*.scc
mssccprj.scc
vssver.scc
vssver2.scc
*.vspscc
*.vssscc

# ----------------------------------------------------------------------------
# Local backup of the legacy source tree (old LumiSoft.Net sources, duplicates).
